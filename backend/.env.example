# Copie para ~/Secrets/ricoapp1/.env ou backend/.env (nunca commitar valores reais)
# development | production (produção exige AUTH_SECRET, DOCS_ENABLED=false, OPEN_FINANCE_API_KEY)
APP_ENV=development
BRAPI_API_KEY=
BRAPI_BASE_URL=https://brapi.dev/api
# Bolsai — proventos, fundamentos TTM, macro BCB. Pro: 10k req/dia.
# Obrigatória em produção — fundamentos/proventos B3 fiéis ao Investidor10.
BOLSAI_API_KEY=
BOLSAI_BASE_URL=https://api.usebolsai.com/api/v1
# free | pro (pro = limites amplos: screener 100 tickers, agenda com catálogo)
BOLSAI_PLAN=pro
BOLSAI_CALENDAR_MAX_TICKERS=350
BOLSAI_CALENDAR_INCLUDE_CATALOG=true
BOLSAI_DY_ENRICH_CONCURRENCY=10
BOLSAI_DY_LIST_MAX_SYMBOLS=100
BOLSAI_TICKER_CACHE_TTL_SECONDS=7200
MARKETSTACK_API_KEY=
MARKETSTACK_BASE_URL=https://api.marketstack.com/v2
# free | basic | professional | business  (aliases: 10=basic, 150=business)
MARKETSTACK_PLAN=basic
# Só usado em professional/business (intraday)
MARKETSTACK_INTRADAY_INTERVAL=5min
MARKETSTACK_REALTIME_CACHE_TTL_SECONDS=60
# Financial Modeling Prep (opcional) — plano grátis: crie a conta e gere a key em
# https://site.financialmodelingprep.com/developer/docs (250 req/dia). Sem chave,
# o enriquecimento do perfil de empresas internacionais é apenas ignorado.
# Ratios TTM (P/L, margens) + key-metrics (ROE) para comparador EUA sem Marketstack Business.
FMP_API_KEY=
FMP_BASE_URL=https://financialmodelingprep.com/stable
FMP_PROFILE_CACHE_TTL_SECONDS=604800
# Teto diário de chamadas FMP (free = 250/dia). Mantemos margem.
FMP_DAILY_REQUEST_BUDGET=230
FMP_NEGATIVE_CACHE_TTL_SECONDS=86400
# Logos: TTL longo em disco + cache negativo para não re-baixar 404.
LOGO_DISK_CACHE_TTL_SECONDS=2592000
LOGO_MEMORY_CACHE_TTL_SECONDS=604800
LOGO_NEGATIVE_CACHE_TTL_SECONDS=43200
LOGO_HTTP_MAX_AGE_SECONDS=2592000
BINANCE_BASE_URL=https://api.binance.com
BINANCE_WS_BASE_URL=wss://stream.binance.com:9443
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_CACHE_TTL_SECONDS=21600
CRYPTO_MACRO_CACHE_TTL_SECONDS=1800
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
PLUGGY_BASE_URL=https://api.pluggy.ai
# Opcional: exige header X-Open-Finance-Key nas rotas /v1/open-finance/*
OPEN_FINANCE_API_KEY=
CORS_ORIGINS=http://127.0.0.1:*,http://localhost:*
# Só use TRUST_PROXY_HEADERS=true atrás de reverse proxy confiável.
TRUST_PROXY_HEADERS=false
RATE_LIMIT_PER_MINUTE=480
# Limite dedicado para /v1/auth/* (login, registro, anônimo).
AUTH_RATE_LIMIT_PER_MINUTE=20
# Limite para rotas */logo.png (pré-carga do app).
LOGO_RATE_LIMIT_PER_MINUTE=120
FII_FUND_CATALOG_TTL_SECONDS=3600
FII_CACHE_TTL_SECONDS=900
API_HOST=127.0.0.1
API_PORT=8000
# Produção: defina um segredo forte (>=32 chars). Vazio = API pública (dev).
AUTH_SECRET=
AUTH_TOKEN_TTL_SECONDS=2592000
# Swagger/ReDoc/OpenAPI: dev=true (padrão), produção=false.
# Com false, /docs, /redoc e /openapi.json retornam 404.
DOCS_ENABLED=true
