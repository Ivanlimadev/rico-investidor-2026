# Copie para backend/.env ou ~/Secrets/ricoapp1/.env

APP_ENV=development
AUTH_SECRET=change-me-to-at-least-32-characters-long

# Dev local (SQLite — padrão se omitido):
DATABASE_URL=sqlite:///./data/ricoapp.db
#
# Postgres (produção ou: docker compose -f docker-compose.postgres.yml up -d):
# DATABASE_URL=postgresql+psycopg://rico:rico@127.0.0.1:5432/ricoapp
#
# Pool opcional (Postgres):
# DATABASE_POOL_SIZE=5
# DATABASE_MAX_OVERFLOW=10

MARKETSTACK_API_KEY=
MARKETSTACK_PLAN=professional

# Saída HTTP para Marketstack/Binance/etc.
# OUTBOUND_HTTP_TRUST_ENV=false ignora proxy do sistema (recomendado no dev).
# OUTBOUND_HTTP_FALLBACK_ENABLED=true tenta direct e depois proxy se a rede falhar.
# OUTBOUND_HTTP_TRUST_ENV=false
# OUTBOUND_HTTP_FALLBACK_ENABLED=true

# Marketstack — preço (rápido) vs listas/heatmap (lento):
# MARKETSTACK_REALTIME_CACHE_TTL_SECONDS=60
# MARKETSTACK_AUX_CACHE_TTL_SECONDS=1800
# MARKETSTACK_STATIC_CACHE_TTL_SECONDS=3600

# Fallback de preço ao vivo quando intraday Marketstack falha (recomendado):
# FMP_API_KEY=

# Plaid (Finanças — mercado US). Sandbox: https://dashboard.plaid.com/
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US

# Release mobile exige: flutter build apk --dart-define=API_BASE_URL=https://api.seudominio.com
